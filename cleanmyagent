#!/usr/bin/env python3
"""cleanmyagent — audit what your coding agents' skills/plugins/MCP actually cost vs. how much you use them.

Reads local files only. No network, no accounts, zero dependencies (Python 3 stdlib).

inventory (SKILL.md descriptions = per-session context tax):
  claude    ~/.claude/skills                + plugins via installed_plugins.json
  agents    ~/.agents/skills                (Agent Skills open standard, shared)
  codex     ~/.codex/skills                 (.system builtins excluded)
  opencode  ~/.config/opencode/skill
  gemini    ~/.gemini/skills                + extensions' bundled skills
  openclaw  ~/.openclaw/skills
  hermes    ~/.hermes/skills

usage:
  claude    ~/.claude/projects/**/*.jsonl   Skill tool calls, /slash commands, mcp__ calls
  codex     ~/.codex/sessions/**/*.jsonl    SKILL.md opens (skill-list injection excluded)
  opencode  ~/.local/share/opencode/opencode.db   part rows: tool=skill
  gemini    ~/.gemini/tmp/**/chats/*.json   activate_skill function calls
  openclaw  ~/.openclaw/agents/**/sessions/*.jsonl   SKILL.md opens (<available_skills> excluded)
  hermes    ~/.hermes/state.db              skill_view tool calls

Skills that ship as part of a managed bundle (Claude plugins, the gstack suite,
Gemini extensions) are judged as a bundle: deleting individual members breaks the
suite or gets reverted on update, so --fix only targets standalone skills and
fully-unused bundles.
"""
import glob
import json
import os
import re
import shutil
import sqlite3
import subprocess
import sys
import threading
import time
from datetime import datetime, timezone

CLAUDE = os.path.expanduser(os.environ.get("CLAUDE_HOME", "~/.claude"))
CODEX = os.path.expanduser(os.environ.get("CODEX_HOME", "~/.codex"))
AGENTS = os.path.expanduser("~/.agents")
OPENCODE_CFG = os.path.expanduser("~/.config/opencode")
OPENCODE_DB = os.path.expanduser("~/.local/share/opencode/opencode.db")
GEMINI = os.path.expanduser("~/.gemini")
OPENCLAW = os.path.expanduser("~/.openclaw")
HERMES = os.path.expanduser("~/.hermes")
STALE_DAYS = 30
GRACE_DAYS = 14  # unused but installed recently → "new", not a delete candidate

COLOR = (sys.stdout.isatty() or bool(os.environ.get("FORCE_COLOR"))) \
    and not os.environ.get("NO_COLOR")


def c(code, s):
    return f"\x1b[{code}m{s}\x1b[0m" if COLOR else s


def bold(s): return c("1", s)
def dim(s): return c("2", s)
def red(s): return c("31", s)
def green(s): return c("32", s)
def yellow(s): return c("33", s)
def cyan(s): return c("36", s)


ANSI_RE = re.compile(r"\x1b\[[0-9;]*m")


def vlen(s):
    return len(ANSI_RE.sub("", s))


def bar(frac, width=20):
    # btop-style meter: per-cell green→yellow→red gradient across the bar
    frac = max(0.0, min(1.0, frac))
    full = round(frac * width)
    if not COLOR:
        return "█" * full + "░" * (width - full)
    cells = []
    for i in range(full):
        t = i / max(width - 1, 1)
        r, g = (int(2 * t * 255), 255) if t < 0.5 else (255, int(2 * (1 - t) * 255))
        cells.append(f"\x1b[38;2;{r};{g};70m█")
    return "".join(cells) + "\x1b[0m" + dim("░" * (width - full))


def clip(s, n):
    """ANSI-aware truncation to n visible chars (escape sequences pass through)."""
    if vlen(s) <= n:
        return s
    out, seen, i = [], 0, 0
    while i < len(s) and seen < n - 1:
        m = ANSI_RE.match(s, i)
        if m:
            out.append(m.group(0))
            i = m.end()
        else:
            out.append(s[i])
            seen += 1
            i += 1
    return "".join(out) + ("\x1b[0m" if COLOR else "") + "…"


def render_box(title, lines, inner):
    """One btop-style panel as a list of equal-width strings."""
    out = [dim("╭─ ") + bold(clip(title, inner - 2))
           + dim(" " + "─" * max(0, inner - vlen(title) - 1) + "╮")]
    for l in lines:
        l = clip(l, inner)
        out.append(dim("│ ") + l + " " * (inner - vlen(l)) + dim(" │"))
    out.append(dim("╰" + "─" * (inner + 2) + "╯"))
    return out


SIDE_W = 60  # right sidebar (utilization, mcp) — btop-style fixed column


def render_layout(main, side, term_w):
    """btop-style page: main column left; utilization/mcp in a fixed right
    sidebar when the terminal is wide enough, stacked below otherwise."""
    if side and term_w >= 150:
        main_w = term_w - SIDE_W - 1
        left = [ln for t, ls in main for ln in render_box(t, ls, main_w - 4)]
        right = [ln for t, ls in side for ln in render_box(t, ls, SIDE_W - 4)]
        blank_l, blank_r = " " * main_w, " " * SIDE_W
        return "\n".join((left[i] if i < len(left) else blank_l) + " "
                         + (right[i] if i < len(right) else blank_r)
                         for i in range(max(len(left), len(right))))
    return "\n".join(ln for t, ls in main + side
                     for ln in render_box(t, ls, term_w - 4))


def est_tokens(s):
    # ponytail: heuristic — ~4 chars/token ascii, ~1.5 chars/token CJK. Good enough for ranking.
    ascii_n = sum(1 for ch in s if ord(ch) < 128)
    return int(ascii_n / 4 + (len(s) - ascii_n) / 1.5)


def read_frontmatter(path):
    """(description, frontmatter keys, body tokens, skill dir has lazy-load subdirs)"""
    try:
        with open(path, encoding="utf-8", errors="replace") as f:
            text = f.read(200000)
    except OSError:
        return "", set(), 0, False
    m = re.match(r"---\n(.*?)\n---", text, re.S)
    fm = m.group(1) if m else ""
    body = text[m.end():] if m else text
    dm = re.search(r"^description:\s*(.*(?:\n[ \t]+.*)*)", fm, re.M)
    desc = dm.group(1).strip().strip("\"'") if dm else ""
    d = os.path.dirname(path)
    refs = any(os.path.isdir(os.path.join(d, s))
               for s in ("references", "reference", "docs", "rules", "examples", "templates"))
    return desc, set(re.findall(r"^([A-Za-z_-]+):", fm, re.M)), est_tokens(body), refs


# distribution fingerprints in frontmatter — hand-made skills rarely carry these
DIST_KEYS = {"version", "platforms", "license", "source", "homepage", "author", "repository"}
# development artifacts — distributed skills ship docs (references/), not eval harnesses
CUSTOM_DIRS = ("scripts", "evals")

ORIGIN_FILE = os.path.expanduser("~/.config/cleanmyagent/origins.json")


def load_origin_overrides():
    try:
        return json.load(open(ORIGIN_FILE))
    except (OSError, ValueError):
        return {}


ORIGIN_OVERRIDES = load_origin_overrides()


def detect_origin(name, path, fm_keys, bundle):
    """custom (you wrote it) / dist (installed from somewhere) / ? (can't tell).
    ponytail: heuristic — brandkit-style installs with bare frontmatter stay '?',
    which --fix treats as 'verify before delete'. Pin exceptions in origins.json."""
    if name in ORIGIN_OVERRIDES:
        return ORIGIN_OVERRIDES[name]
    if bundle:
        return "dist"
    if fm_keys & DIST_KEYS:
        return "dist"
    d = os.path.dirname(path)
    if any(os.path.isdir(os.path.join(d, s)) for s in CUSTOM_DIRS):
        return "custom"
    # hand-made skills keep getting edited; installs stay frozen at install time
    try:
        st = os.stat(d)
        born = getattr(st, "st_birthtime", st.st_mtime)
        newest = max((os.stat(os.path.join(dp, f)).st_mtime
                      for dp, _, fs in os.walk(d) for f in fs), default=born)
        if newest > born + 86400:
            return "custom"
    except OSError:
        pass
    return "?"


# ---------------------------------------------------------------- inventory

def birthtime(path):
    """Creation time of the skill dir (mtime fallback) as ISO — the install date."""
    d = os.path.dirname(path)
    try:
        st = os.stat(d)
        t = getattr(st, "st_birthtime", st.st_mtime)
    except OSError:
        return ""
    return datetime.fromtimestamp(t, timezone.utc).isoformat()


def gstack_members():
    """gstack installs its repo at <skills>/gstack — its skill subdirs define the suite."""
    members = set()
    for base in (CLAUDE, AGENTS):
        root = os.path.join(base, "skills", "gstack")
        if not os.path.isdir(root):
            continue
        members.add("gstack")
        for name in os.listdir(root):
            if os.path.isfile(os.path.join(root, name, "SKILL.md")):
                members.add(name)
    return members


GSTACK = gstack_members()


def scan_skill_dir(inv, skills_dir, source, bundle=None):
    if not os.path.isdir(skills_dir):
        return
    for name in sorted(os.listdir(skills_dir)):
        if name.startswith("."):  # .system etc = agent builtins, not yours to delete
            continue
        p = os.path.join(skills_dir, name, "SKILL.md")
        if not os.path.isfile(p):
            continue
        desc, fm_keys, body, refs = read_frontmatter(p)
        # gstack suite: membership from its repo dir; "(gstack)" desc suffix as fallback
        b = bundle or ("gstack" if name in GSTACK or re.search(r"\(gstack\)\s*$", desc) else None)
        if name in inv:
            if source not in inv[name]["sources"]:
                inv[name]["sources"].append(source)
            inv[name]["installed"] = min(inv[name]["installed"], birthtime(p))
            continue
        inv[name] = {"sources": [source], "cost": est_tokens(name + desc),
                     "path": p, "bundle": b, "installed": birthtime(p),
                     "origin": detect_origin(name, p, fm_keys, b),
                     "body": body, "refs": refs,
                     "desc_seps": desc.count(",") + desc.count("·")}


def inventory():
    """{key: {sources, cost, path, bundle}} — same skill in several dirs = one row."""
    inv = {}
    scan_skill_dir(inv, os.path.join(CLAUDE, "skills"), "claude")
    scan_skill_dir(inv, os.path.join(AGENTS, "skills"), "agents")
    scan_skill_dir(inv, os.path.join(CODEX, "skills"), "codex")
    scan_skill_dir(inv, os.path.join(OPENCODE_CFG, "skill"), "opencode")
    scan_skill_dir(inv, os.path.join(OPENCODE_CFG, "skills"), "opencode")
    scan_skill_dir(inv, os.path.join(GEMINI, "skills"), "gemini")
    scan_skill_dir(inv, os.path.join(OPENCLAW, "skills"), "openclaw")
    scan_skill_dir(inv, os.path.join(HERMES, "skills"), "hermes")

    # gemini extensions may bundle skills
    for sdir in glob.glob(os.path.join(GEMINI, "extensions", "*", "skills")):
        ext = os.path.basename(os.path.dirname(sdir))
        scan_skill_dir(inv, sdir, "gemini", bundle=f"gemini-ext:{ext}")

    # claude plugins: installPath/skills/<name>, invoked as "plugin:name"
    manifest = os.path.join(CLAUDE, "plugins", "installed_plugins.json")
    try:
        plugins = json.load(open(manifest)).get("plugins", {})
    except (OSError, ValueError):
        plugins = {}
    for full_name, installs in plugins.items():
        plugin, _, market = full_name.partition("@")
        for root in {i.get("installPath") for i in installs if i.get("installPath")}:
            sdir = os.path.join(root, "skills")
            if not os.path.isdir(sdir):
                continue
            for name in sorted(os.listdir(sdir)):
                p = os.path.join(sdir, name, "SKILL.md")
                key = f"{plugin}:{name}"
                if os.path.isfile(p) and key not in inv:
                    desc, _, body, refs = read_frontmatter(p)
                    inv[key] = {"sources": ["claude"], "cost": est_tokens(key + desc),
                                "path": p, "bundle": f"plugin:{plugin}",
                                "marketplace": market, "installed": birthtime(p),
                                "origin": "dist", "body": body, "refs": refs,
                                "desc_seps": desc.count(",") + desc.count("·")}
    return inv


# ---------------------------------------------------------------- usage

SKILL_RE = re.compile(r'"skill"\s*:\s*"([^"]+)"')
CMD_RE = re.compile(r"<command-name>/?([\w:-]+)</command-name>")
MCP_RE = re.compile(r'"name"\s*:\s*"mcp__([A-Za-z0-9_]+?)__([A-Za-z0-9_]+)"')
TS_RE = re.compile(r'"timestamp"\s*:\s*"([^"]+)"')
CODEX_SKILL_RE = re.compile(r"skills/([A-Za-z0-9_.-]+)/SKILL\.md")


class Progress:
    """Transient stderr progress — the claude scan alone chews 10s+ of transcripts,
    so a background ticker keeps elapsed time and event count moving."""
    FRAMES = "⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏"

    def __init__(self):
        self.on = sys.stderr.isatty()
        self.msg, self.n, self.t0, self.i = "", 0, time.time(), 0
        if self.on:
            self._stop = threading.Event()
            threading.Thread(target=self._tick, daemon=True).start()

    def _tick(self):
        while not self._stop.wait(0.1):
            self._draw()

    def _draw(self):
        self.i += 1
        spin = self.FRAMES[self.i % len(self.FRAMES)]
        cnt = f" · {self.n:,} events" if self.n else ""
        sys.stderr.write(f"\r\x1b[2K\x1b[2m{spin} {self.msg}{cnt}"
                         f" · {time.time() - self.t0:.1f}s\x1b[0m")
        sys.stderr.flush()

    def stage(self, msg):
        self.msg = msg

    def done(self):
        if self.on:
            self._stop.set()
            sys.stderr.write("\r\x1b[2K")
            sys.stderr.flush()


PROG = Progress()


def bump(d, key, ts):
    cnt, last = d.get(key, (0, ""))
    d[key] = (cnt + 1, max(last, ts or ""))


def grep_lines(patterns, root, include="*.jsonl"):
    """Yield matching lines via grep — transcripts are hundreds of MB, let C scan."""
    if not os.path.isdir(root):
        return
    cmd = ["grep", "-rh", f"--include={include}"]
    for p in patterns:
        cmd += ["-e", p]
    cmd.append(root)
    proc = subprocess.Popen(cmd, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL,
                            text=True, errors="replace")
    yield from proc.stdout
    proc.wait()


def usage_claude(skills, mcp):
    for line in grep_lines(['"name":"Skill"', "command-name", '"name":"mcp__'],
                           os.path.join(CLAUDE, "projects")):
        PROG.n += 1
        ts_m = TS_RE.search(line)
        ts = ts_m.group(1) if ts_m else ""
        if '"name":"Skill"' in line:
            m = SKILL_RE.search(line)
            if m:
                bump(skills, m.group(1), ts)
        elif "command-name" in line:
            m = CMD_RE.search(line)
            if m:
                bump(skills, m.group(1), ts)
        for m in MCP_RE.finditer(line):
            key = m.group(1)
            cnt, first, last, tools = mcp.get(key, (0, "9", "", set()))
            tools.add(m.group(2))
            mcp[key] = (cnt + 1, min(first, ts or "9"), max(last, ts or ""), tools)


def usage_skillmd_mentions(skills, root, list_marker):
    # Codex/OpenClaw use a skill by opening its SKILL.md; the per-session
    # skill-list injection (list_marker) is excluded so listing != using.
    # ponytail: mention ≈ use — good enough for keep/delete ranking.
    for line in grep_lines(["SKILL.md"], root):
        PROG.n += 1
        if list_marker in line:
            continue
        ts_m = TS_RE.search(line)
        ts = ts_m.group(1) if ts_m else ""
        for name in set(CODEX_SKILL_RE.findall(line)):
            if not name.startswith("."):
                bump(skills, name, ts)


def usage_opencode(skills):
    if not os.path.isfile(OPENCODE_DB):
        return
    try:
        db = sqlite3.connect(f"file:{OPENCODE_DB}?mode=ro", uri=True)
        rows = db.execute(
            "SELECT data, time_created FROM part WHERE data LIKE '%\"tool\":\"skill\"%'"
        ).fetchall()
        db.close()
    except sqlite3.Error:
        return
    for data, ms in rows:
        try:
            d = json.loads(data)
            name = d["state"]["input"]["name"]
        except (ValueError, KeyError, TypeError):
            continue
        ts = datetime.fromtimestamp(ms / 1000, timezone.utc).isoformat()
        bump(skills, name, ts)


def usage_gemini(skills):
    # chats/*.json hold full transcripts incl. functionCall activate_skill {name}
    for f in glob.glob(os.path.join(GEMINI, "tmp", "*", "chats", "*.json")):
        try:
            text = open(f, encoding="utf-8", errors="replace").read()
        except OSError:
            continue
        if "activate_skill" not in text:
            continue
        mtime = datetime.fromtimestamp(os.path.getmtime(f), timezone.utc).isoformat()
        for m in re.finditer(
                r'"activate_skill"[^}]*?"args"\s*:\s*\{[^}]*?"name"\s*:\s*"([^"]+)"', text):
            bump(skills, m.group(1), mtime)


def usage_hermes(skills):
    # Hermes Agent logs tool calls in state.db; skills are used via skill_view {name}
    db_path = os.path.join(HERMES, "state.db")
    if not os.path.isfile(db_path):
        return
    try:
        db = sqlite3.connect(f"file:{db_path}?mode=ro", uri=True)
        rows = db.execute(
            "SELECT tool_calls, timestamp FROM messages "
            "WHERE tool_calls LIKE '%skill_view%'").fetchall()
        db.close()
    except sqlite3.Error:
        return
    for tool_calls, epoch in rows:
        try:
            calls = json.loads(tool_calls)
        except (ValueError, TypeError):
            continue
        ts = datetime.fromtimestamp(epoch or 0, timezone.utc).isoformat()
        for call in calls:
            fn = call.get("function", {})
            if fn.get("name") != "skill_view":
                continue
            try:
                name = json.loads(fn.get("arguments", "{}")).get("name")
            except ValueError:
                continue
            if name:
                bump(skills, name, ts)


def usage_gstack(skills):
    # gstack keeps its own invocation log — most reliable source for its suite
    log = os.path.expanduser("~/.gstack/analytics/skill-usage.jsonl")
    try:
        for line in open(log, encoding="utf-8", errors="replace"):
            try:
                d = json.loads(line)
                bump(skills, d["skill"], d.get("ts", ""))
            except (ValueError, KeyError):
                continue
    except OSError:
        pass


def usage():
    skills, mcp = {}, {}
    for label, fn in (
            ("claude-code transcripts", lambda: usage_claude(skills, mcp)),
            ("codex sessions", lambda: usage_skillmd_mentions(
                skills, os.path.join(CODEX, "sessions"), "### Available skills")),
            ("openclaw sessions", lambda: usage_skillmd_mentions(
                skills, os.path.join(OPENCLAW, "agents"), "<available_skills>")),
            ("opencode db", lambda: usage_opencode(skills)),
            ("gemini chats", lambda: usage_gemini(skills)),
            ("hermes db", lambda: usage_hermes(skills)),
            ("gstack analytics", lambda: usage_gstack(skills))):
        PROG.stage(f"scanning {label} …")
        fn()
    PROG.done()
    return skills, mcp


def configured_mcp():
    """MCP servers configured for Claude Code (global + per-project)."""
    servers = set()
    try:
        cfg = json.load(open(os.path.expanduser("~/.claude.json")))
    except (OSError, ValueError):
        return servers
    servers.update(cfg.get("mcpServers", {}))
    for proj in cfg.get("projects", {}).values():
        servers.update(proj.get("mcpServers", {}))
    return servers


# ---------------------------------------------------------------- verdicts

def age_days(iso):
    if not iso:
        return None
    try:
        dt = datetime.fromisoformat(iso.replace("Z", "+00:00"))
    except ValueError:
        return None
    return (datetime.now(timezone.utc) - dt).days


def fmt_last(iso):
    d = age_days(iso)
    if d is None:
        return "—"
    return "today" if d == 0 else f"{d}d ago"


def verdict(row):
    if row["bundle"]:
        return ("bundle", "· bundle")  # judged at bundle level
    if row["uses"] == 0:
        a = age_days(row["installed"])
        if a is not None and a < GRACE_DAYS:
            return ("new", f"◦ new ({a}d)")  # too fresh to judge
        return ("unused", "✗ unused")
    d = age_days(row["last"])
    if d is not None and d > STALE_DAYS:
        return ("stale", f"◌ stale {d}d")
    return ("keep", "✓ keep")


def build_rows(inv, skill_use):
    rows = []
    for key, meta in inv.items():
        cnt, last = skill_use.get(key, (0, ""))
        row = {"name": key, "sources": meta["sources"], "cost": meta["cost"],
               "path": meta["path"], "bundle": meta["bundle"],
               "marketplace": meta.get("marketplace", ""), "uses": cnt, "last": last,
               "installed": meta.get("installed", ""), "origin": meta.get("origin", "?"),
               "body": meta.get("body", 0), "refs": meta.get("refs", False),
               "desc_seps": meta.get("desc_seps", 0)}
        row["status"], row["verdict"] = verdict(row)
        rows.append(row)
    return rows


def fix_commands(rows, mcp_rows):
    """Cleanup commands. Printed, never executed. Bundle-aware."""
    cmds = []
    standalone = [r for r in rows if not r["bundle"]]
    bundles = {}
    for r in rows:
        if r["bundle"]:
            bundles.setdefault(r["bundle"], []).append(r)

    for r in standalone:
        if r["status"] == "unused":  # "new" installs get a grace period
            # hand-made (or unverifiable) skills are shown but not armed —
            # a custom skill is often irreplaceable knowledge, not a reinstall away
            guard = "# REVIEW (looks hand-made): " if r["origin"] == "custom" else \
                    "# VERIFY (origin unknown): " if r["origin"] == "?" else ""
            # a skill can live in several skill dirs (inventory dedupes) — rm every copy
            for base in (os.path.join(CLAUDE, "skills"), os.path.join(AGENTS, "skills"),
                         os.path.join(CODEX, "skills"), os.path.join(OPENCODE_CFG, "skill"),
                         os.path.join(OPENCODE_CFG, "skills"), os.path.join(GEMINI, "skills"),
                         os.path.join(OPENCLAW, "skills"), os.path.join(HERMES, "skills")):
                d = os.path.join(base, r["name"])
                if os.path.isdir(d):
                    cmds.append(f"{guard}rm -rf {d}")

    for bundle, brows in sorted(bundles.items()):
        used = sum(1 for r in brows if r["uses"] > 0)
        ages = [age_days(r["installed"]) for r in brows]
        if used or any(a is not None and a < GRACE_DAYS for a in ages):
            continue  # used, or freshly installed — kept whole
        n = len(brows)
        if bundle.startswith("plugin:"):
            cmds.append(f"claude plugin disable {bundle[7:]}  # all {n} skills unused")
        elif bundle.startswith("gemini-ext:"):
            cmds.append(f"gemini extensions uninstall {bundle[11:]}  # all {n} skills unused")
        elif bundle == "gstack":
            cmds.append(f"# gstack suite: all {n} skills unused — remove via gstack itself, not rm")

    for r in mcp_rows:
        if r["uses"] == 0:
            cmds.append(f"claude mcp remove {r['server']}  # configured, never called")
    return cmds


# ---------------------------------------------------------------- report

VERDICT_PAINT = {"unused": red, "stale": yellow, "keep": green, "bundle": dim, "new": cyan}


def fmt_installed(iso):
    d = age_days(iso)
    if d is None:
        return "—"
    return "today" if d == 0 else f"{d}d" if d < 365 else f"{d // 365}y{d % 365 // 30}m"


STATUS_ORDER = {"unused": 0, "stale": 1, "new": 2, "bundle": 3, "keep": 3}

# ISO timestamps sort lexically; "" sorts first, so flag empties to keep them last
SORTS = {
    # action order: delete candidates (big cost first) → stale → new → keep (most used first)
    "action": lambda r: (STATUS_ORDER.get(r["status"], 3),
                         -r["uses"] if r["status"] in ("keep", "bundle") and r["uses"] else 0,
                         -r["cost"]),
    "cost": lambda r: -r["cost"],
    "uses": lambda r: -r["uses"],
    "installed": lambda r: (r["installed"] == "", r["installed"]),          # oldest first
    "last": lambda r: (r["last"] == "", [-ord(ch) for ch in r["last"]]),    # most recent first
    "name": lambda r: r["name"],
}


def sort_key(r):
    return SORTS["action"](r)


# green → lime → amber → orange → red; piecewise lerp keeps midtones vivid
WASTE_STOPS = [(34, 160, 84), (132, 176, 60), (233, 158, 38), (238, 108, 46), (225, 62, 62)]


def waste_bg(waste):
    x = min(max(waste, 0.0), 1.0) * (len(WASTE_STOPS) - 1)
    i = min(int(x), len(WASTE_STOPS) - 2)
    t = x - i
    a, b = WASTE_STOPS[i], WASTE_STOPS[i + 1]
    r, g, bl = (int(a[k] + (b[k] - a[k]) * t) for k in range(3))
    return f"48;2;{r};{g};{bl}"


def tax_map(rows, width):
    """strip treemap at group granularity (150 skills is mush; ~12 groups read):
    groups flow into 2-3 strips of 3-row blocks — area ∝ tokens per session,
    color = share of that spend that is never-used waste."""
    groups = {}
    for r in rows:
        groups.setdefault(r["bundle"] or "standalone", []).append(r)
    segs = []  # (label, cost, waste_frac, used, total_skills)
    for gname, rs in groups.items():
        cost = sum(r["cost"] for r in rs)
        dead = sum(r["cost"] for r in rs if r["uses"] == 0)
        segs.append((gname.replace("plugin:", ""), cost, dead / cost if cost else 0,
                     sum(1 for r in rs if r["uses"] > 0), len(rs)))
    segs.sort(key=lambda s: -s[1])
    total = sum(s[1] for s in segs) or 1

    # greedy strip packing: each strip holds ~equal token mass
    nstrips = 3 if len(segs) > 8 else 2 if len(segs) > 3 else 1
    target, strips, cur, acc = total / nstrips, [], [], 0
    for s in segs:
        cur.append(s)
        acc += s[1]
        if acc >= target and len(strips) < nstrips - 1:
            strips.append(cur)
            cur, acc = [], 0
    if cur:
        strips.append(cur)

    lines = []
    for strip in strips:
        stotal = sum(s[1] for s in strip) or 1
        # segments too narrow to label merge into one "+N others" block
        prov = [round(c / stotal * (width - (len(strip) - 1))) for _, c, *_ in strip]
        cut = next((i for i, n in enumerate(prov) if n < 16 and i > 0), len(strip))
        if cut < len(strip) - 1 or (cut < len(strip) and prov[cut] < 16):
            tail = strip[cut:]
            tc = sum(s[1] for s in tail) or 1
            strip = strip[:cut] + [(f"+{len(tail)} others", tc,
                                    sum(s[1] * s[2] for s in tail) / tc,
                                    sum(s[3] for s in tail), sum(s[4] for s in tail))]
        gaps = len(strip) - 1
        avail = width - gaps
        stotal = sum(s[1] for s in strip) or 1
        widths = [max(10, round(c / stotal * avail)) for _, c, *_ in strip]
        widths[-1] = avail - sum(widths[:-1])  # exact fit, no overflow past the box
        if widths[-1] < 10 and len(widths) > 1:  # rounding pushed the last one under
            widths[0] += widths[-1] - 10
            widths[-1] = 10
        row_name, row_tok, row_use = [], [], []
        for (label, cost, waste, used, n_skills), n in zip(strip, widths):
            bg = waste_bg(waste)
            row_name.append(f"\x1b[30;1;{bg}m{(' ' + label)[:n].ljust(n)}\x1b[0m")
            row_tok.append(f"\x1b[30;{bg}m{(' %s tok · %.0f%%✗' % (format(cost, ','), waste * 100))[:n].ljust(n)}\x1b[0m")
            row_use.append(f"\x1b[30;{bg}m{(' %d/%d skills used' % (used, n_skills))[:n].ljust(n)}\x1b[0m")
        lines += [" ".join(row_name), " ".join(row_tok), " ".join(row_use), ""]
    lines.append(dim("area ∝ tokens/session · color = never-used share "
                     "(green all earning → red all waste)"))
    return lines


def table_lines(rows, width, max_cost):
    lines = []
    for r in rows:
        paint = VERDICT_PAINT[r["status"]]
        name = r["name"] if len(r["name"]) <= width else r["name"][:width - 1] + "…"
        name = f"{name:<{width}}"
        origin = {"custom": cyan("✎ custom"), "dist": dim("dist"), "?": yellow("?")}[r["origin"]]
        lines.append(f"{name if r['status'] != 'unused' else dim(name)}  "
                     f"{origin}{' ' * (8 - vlen(origin))}  "
                     f"{r['cost']:>5} {bar(r['cost'] / max_cost, 6)}  "
                     f"{fmt_installed(r['installed']):>9}  "
                     f"{r['uses'] if r['uses'] else '·':>5}  "
                     f"{fmt_last(r['last']):>8}  {paint(r['verdict']):<14}")
    return lines


def utilization_line(label, used, total, width=24):
    pct = used / total if total else 0
    return f"{label:<{width}} {used:>4}/{total:<4} {bar(pct, 16)} {pct:>4.0%}"


def report(rows, mcp_rows, sort="action", rev=False, full_hints=False):
    key = SORTS.get(sort, SORTS["action"])
    standalone = sorted([r for r in rows if not r["bundle"]], key=key, reverse=rev)
    bundles = {}
    for r in rows:
        if r["bundle"]:
            bundles.setdefault(r["bundle"], []).append(r)

    total = sum(r["cost"] for r in rows)
    dead = [r for r in rows if r["uses"] == 0]
    dead_cost = sum(r["cost"] for r in dead)
    agents = ["claude-code" if os.path.isdir(os.path.join(CLAUDE, "projects")) else None,
              "codex" if os.path.isdir(os.path.join(CODEX, "sessions")) else None,
              "opencode" if os.path.isfile(OPENCODE_DB) else None,
              "gemini" if os.path.isdir(GEMINI) else None,
              "openclaw" if os.path.isdir(OPENCLAW) else None,
              "hermes" if os.path.isdir(HERMES) else None]

    w = max(max((len(r["name"]) for r in rows), default=10), 10)
    # responsive: name column stretches/shrinks with the terminal
    # fixed columns: origin 8 + tok 12 + installed 9 + uses 5 + last 8 + verdict 14
    # + 6 gaps of 2 + box borders 4 = 72
    term_w = shutil.get_terminal_size((120, 24)).columns
    sidebar = term_w >= 150
    main_w = term_w - SIDE_W - 1 if sidebar else term_w
    w = max(18, min(w, main_w - 72))
    max_cost = max((r["cost"] for r in rows), default=1) or 1
    header = dim(f"{'SKILL':<{w}}  {'ORIGIN':<8}  {'TOK/SESSION':>12}  {'INSTALLED':>9}  "
                 f"{'USES':>5}  {'LAST':>8}  {'VERDICT':<14}")

    frac = dead_cost / total if total else 0
    panels = [(f"cleanmyagent · {datetime.now().strftime('%Y-%m-%d')}", [
        dim("agents  ") + " · ".join(a for a in agents if a),
        "",
        f"{'context tax / session':<22} {bar(1.0, 28)} ~{total:,} tok",
        f"{'never-used share':<22} {bar(frac, 28)} ~{dead_cost:,} tok ({frac:.0%})",
        "",
        dim("TOK/SESSION = tokens this skill's description force-loads into"),
        dim("every single session, used or not — that's the context tax"),
    ])]

    if COLOR:  # the map is pure color — nothing to show on pipes/NO_COLOR
        panels.append(("context-tax map", tax_map(rows, main_w - 4)))

    # design hints: only the description is force-loaded every session; the SKILL.md
    # body loads on invoke, references/ load on demand. Structural anti-patterns:
    hints = []
    # structural hints only for skills you can actually edit (custom/unknown,
    # not bundle members) — a plugin's internals are upstream's problem
    dist_monoliths = sum(1 for r in rows if (r["bundle"] or r["origin"] == "dist")
                         and r["body"] > 2500 and not r["refs"])
    for r in rows:
        if r["bundle"] or r["origin"] == "dist":
            continue
        # [session] hints hit the always-loaded budget — the core anti-patterns
        if r["cost"] > 200:
            hints.append((r, 0, r["cost"], f"desc {r['cost']:,} tok — paid EVERY session; "
                                           "keep trigger phrases, move detail into the body"))
        elif r["desc_seps"] > 15:
            hints.append((r, 0, r["cost"], f"desc {r['cost']:,} tok, keyword catalog "
                                           f"({r['desc_seps']} separators) — collapse into "
                                           "trigger patterns"))
        if 0 < r["body"] < r["cost"]:
            hints.append((r, 0, r["cost"], f"desc ({r['cost']:,} tok) longer than body "
                                           f"({r['body']:,} tok) — the tax outweighs the payload"))
        # [invoke] hints only matter for skills you actually invoke — weighted by use
        if r["body"] > 2500 and not r["refs"] and r["uses"] > 0:
            hints.append((r, 1, r["body"] * r["uses"],
                          f"body {r['body']:,} tok × {r['uses']} invokes — loads whole "
                          "each time; split into references/ (loads on demand)"))
    # bundle/plugin anti-pattern: paying a suite-sized session tax for a sliver of use
    for bundle, brows in bundles.items():
        used = sum(1 for r in brows if r["uses"] > 0)
        bcost = sum(r["cost"] for r in brows)
        if brows and used / len(brows) < 0.25 and bcost > 800:
            what = f"claude plugin disable {bundle[7:]}" if bundle.startswith("plugin:") \
                else "disable the suite"
            hints.append(({"name": bundle}, 0, bcost,
                          f"{used}/{len(brows)} skills used for ~{bcost:,} tok EVERY session "
                          f"— {what}, re-enable when needed"))
    # MCP anti-pattern: a server whose schemas ride along for 1-2 niche tools
    for r in mcp_rows:
        if r["uses"] and len(r["tools_used"]) <= 2 and r["uses"] < 10:
            hints.append(({"name": r["server"]}, 0, 0,
                          f"mcp server used {r['uses']}× via {len(r['tools_used'])} tool(s) "
                          "— its whole tool schema loads every session; consider removing"))

    # session-tax issues first (the tool's thesis), invoke-cost issues after
    hints.sort(key=lambda h: (h[1], -h[2]))
    if hints:
        tag = [cyan("[session]"), dim("[invoke] ")]
        shown = hints if full_hints else hints[:12]
        lines = [f"{yellow('▲')} {tag[h[1]]} {h[0]['name']:<{w}}  {dim(h[3])}"
                 for h in shown]
        if len(hints) > len(shown):
            more = dim(f"  … {len(hints) - len(shown)} more")
            lines.append(more + (dim(" — press ") + bold("h") if INTERACTIVE else
                                 dim(" — see --json")))
        lines.append("")
        if dist_monoliths:
            lines.append(dim(f"(+{dist_monoliths} distributed skills have monolithic bodies — "
                             "upstream's problem, not yours)"))
        lines.append(dim("loading model: description = every session · body = on invoke · "
                         "references/ = on demand"))
        lines.append(dim("run /skill-judge or /skill-creator on the flagged skills to restructure"))
        panels.append((f"design hints · {len(hints)} structural issues", lines))

    panels.append((f"standalone skills ({len(standalone)})",
                   [header] + table_lines(standalone, w, max_cost)))

    for bundle, brows in sorted(bundles.items(), key=lambda kv: -len(kv[1])):
        brows.sort(key=key, reverse=rev)
        used = sum(1 for r in brows if r["uses"] > 0)
        market = next((r["marketplace"] for r in brows if r.get("marketplace")), "")
        lines = [utilization_line("suite utilization", used, len(brows))]
        if used:
            lines.append(dim("members are kept together — deleting one breaks/reverts on update"))
        lines += ["", header] + table_lines(brows, w, max_cost)
        tag = f" @{market}" if market else ""
        panels.append((f"{bundle}{tag} · {len(brows)} skills", lines))

    # right sidebar: worst utilization first — the offenders float to the top
    groups = [("standalone skills",
               sum(1 for r in standalone if r["uses"] > 0), len(standalone))]
    for bundle, brows in bundles.items():
        groups.append((bundle, sum(1 for r in brows if r["uses"] > 0), len(brows)))
    groups.sort(key=lambda g: g[1] / g[2] if g[2] else 0)
    util = [utilization_line(*g) for g in groups]
    if mcp_rows:
        util.append("")
        util.append(utilization_line("mcp servers",
                                     sum(1 for r in mcp_rows if r["uses"] > 0), len(mcp_rows)))
    side = [("utilization · worst first", util)]

    if mcp_rows:
        lines = [dim(f"{'SERVER':<27}{'CALLS':>6} {'TOOLS':>5} {'LAST':>9}")]
        for r in mcp_rows:
            if r["uses"]:
                lines.append(f"{green('✓')} {clip(r['server'], 25):<25}"
                             f"{r['uses']:>6} {len(r['tools_used']):>5} "
                             f"{fmt_last(r['last']):>9}")
            else:
                lines.append(f"{red('✗')} {r['server']:<25} {dim('never called')}")
        lines.append(dim("first call seen ≈ install date (config has none)"))
        side.append(("mcp servers", lines))

    print()
    print(render_layout(panels, side, term_w))
    arrow = "↑" if rev else "↓"
    hint = f"sorted by {bold(sort)} {arrow}"
    if INTERACTIVE:
        hint += dim(" · ") + bold("a") + dim("ction ") + bold("c") + dim("ost ") \
             + bold("u") + dim("ses ") + bold("i") + dim("nstalled ") + bold("l") + dim("ast ") \
             + bold("n") + dim("ame · same key = reverse · ") + bold("h") + dim(" all hints · ") \
             + bold("q") + dim(" quit")
    print(dim("run with ") + bold("--fix") + dim(" to print cleanup commands (nothing is executed)"))
    print(hint + "\n")


SORT_KEYS = {"a": "action", "c": "cost", "u": "uses", "i": "installed", "l": "last", "n": "name"}
INTERACTIVE = False


def interactive_loop(rows, mcp_rows, sort):
    # btop-style: one keypress → instant re-render (data is already in memory).
    # Runs in the alternate screen buffer so re-renders leave no ghosting and
    # quitting restores the shell exactly as it was.
    import termios
    import tty
    fd = sys.stdin.fileno()
    rev, full_hints, in_alt = False, False, False
    try:
        while True:
            old = termios.tcgetattr(fd)
            try:
                tty.setcbreak(fd)
                ch = sys.stdin.read(1).lower()
            finally:
                termios.tcsetattr(fd, termios.TCSADRAIN, old)
            if ch in ("q", "\x03", "\x04"):
                return
            if ch == "h":
                full_hints = not full_hints
            elif ch in SORT_KEYS:
                if SORT_KEYS[ch] == sort:
                    rev = not rev  # same key again flips the direction
                else:
                    sort, rev = SORT_KEYS[ch], False
            else:
                continue
            if not in_alt:
                sys.stdout.write("\x1b[?1049h")
                in_alt = True
            sys.stdout.write("\x1b[2J\x1b[H")
            report(rows, mcp_rows, sort, rev, full_hints)
    finally:
        if in_alt:
            sys.stdout.write("\x1b[?1049l")
            sys.stdout.flush()


def main():
    global INTERACTIVE
    args = sys.argv[1:]
    sort = "action"
    for i, a in enumerate(args):
        if a.startswith("--sort"):
            sort = a.split("=", 1)[1] if "=" in a else \
                   (args[i + 1] if i + 1 < len(args) else "action")
            if sort not in SORTS:
                sys.exit(f"unknown sort '{sort}' — one of: {', '.join(SORTS)}")

    inv = inventory()
    skill_use, mcp_use = usage()
    rows = build_rows(inv, skill_use)
    rows.sort(key=sort_key)

    for s in configured_mcp():
        mcp_use.setdefault(s, (0, "9", "", set()))
    mcp_rows = [{"server": k, "uses": n, "first": ("" if f == "9" else f), "last": t,
                 "tools_used": sorted(tools)}
                for k, (n, f, t, tools) in sorted(mcp_use.items(), key=lambda kv: -kv[1][0])]

    if "--fix" in args:
        for cmd in fix_commands(rows, mcp_rows):
            print(cmd)
    elif "--json" in args:
        json.dump({"skills": rows, "mcp": mcp_rows}, sys.stdout,
                  ensure_ascii=False, indent=2)
        print()
    else:
        INTERACTIVE = sys.stdout.isatty() and sys.stdin.isatty()
        report(rows, mcp_rows, sort)
        if INTERACTIVE:
            try:
                interactive_loop(rows, mcp_rows, sort)
            except (ImportError, OSError, KeyboardInterrupt):
                pass


if __name__ == "__main__":
    main()
